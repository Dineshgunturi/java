class Arithmetic {
    int add(int a, int b) {
        return a + b;
    }
}

class Adder extends Arithmetic {
    // No extra code needed, it inherits add()
}

public class Solution {
    public static void main(String[] args) {
        Adder obj = new Adder();
        
        System.out.println("My superclass is: " + obj.getClass().getSuperclass().getSimpleName());
        
        System.out.print(obj.add(10, 32) + " ");
        System.out.print(obj.add(10, 3) + " ");
        System.out.print(obj.add(10, 10) + "\n");
    }
}
